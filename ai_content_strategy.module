  'content_gaps' => 'Generate more ideas',
  'authority_topics' => 'Generate more ideas',
  'expertise_demonstrations' => 'Generate more ideas',
  'trust_signals' => 'Generate more ideas',
];

/**
 * Add more recommendations buttons.
 */
const AI_CONTENT_STRATEGY_BUTTON_ADD_MORE = [
  'content_gaps' => 'Discover More %types',
  'authority_topics' => 'Explore More %types',
  'expertise_demonstrations' => 'Add More Ways to Showcase %types',
  'trust_signals' => 'Find More %types',
];

/**
 * Gets translated button texts.
 *
 * @return array
 *   Array of translated button texts.
 */
function ai_content_strategy_get_button_texts() {
  return [
    'main' => [
      'generate' => t('Generate recommendations'),
      'refresh' => t('Refresh recommendations'),
      'loading' => t('Generating recommendations...'),
      'loading_more' => t('Adding more recommendations...'),
    ],
    'generate' => [
      'content_gaps' => t('Generate @type', ['@type' => t('ideas')]),
      'authority_topics' => t('Generate @type', ['@type' => t('ideas')]),
      'expertise_demonstrations' => t('Generate @type', ['@type' => t('ideas')]),
      'trust_signals' => t('Generate @type', ['@type' => t('ideas')]),
    ],
    'generate_more' => [
      'content_gaps' => t('Generate more @type', ['@type' => t('ideas')]),
      'authority_topics' => t('Generate more @type', ['@type' => t('ideas')]),
      'expertise_demonstrations' => t('Generate more @type', ['@type' => t('ideas')]),
      'trust_signals' => t('Generate more @type', ['@type' => t('ideas')]),
    ],
    'add_more' => [
      'content_gaps' => t('Generate more @type', ['@type' => t('cards')]),
      'authority_topics' => t('Generate more @type', ['@type' => t('cards')]),
      'expertise_demonstrations' => t('Generate more @type', ['@type' => t('cards')]),
      'trust_signals' => t('Generate more @type', ['@type' => t('cards')]),
    ],
  ];
}

/**
 * Implements hook_theme().
 */
function ai_content_strategy_theme() {
  return [
    'ai_content_strategy_recommendations' => [
      'variables' => [
        'content_gaps' => [],
        'authority_topics' => [],
        'expertise_demonstrations' => [],
        'trust_signals' => [],
        'button_text' => [],
        'last_run' => NULL,
      ],
    ],
    'ai_content_strategy_recommendations_items' => [
      'variables' => [
        'items' => [],
        'section' => NULL,
        'section_config' => [],
        'button_text' => [],
      ],
    ],
  ];
}

/**
 * Implements hook_preprocess_HOOK().
 */
function ai_content_strategy_preprocess_ai_content_strategy_recommendations(&$variables) {
  // Get translated button texts
  $variables['button_text'] = ai_content_strategy_get_button_texts();

  // Get last run time from state if available
  $last_run = \Drupal::state()->get('ai_content_strategy.last_run');
  if ($last_run) {
    $variables['last_run'] = \Drupal::service('date.formatter')->formatTimeDiffSince($last_run);
  }

  // Add to JavaScript settings
  $variables['#attached']['drupalSettings']['aiContentStrategy'] = [
    'buttonText' => $variables['button_text'],
  ];
} 
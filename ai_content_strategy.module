<?php

/**
 * Implements hook_theme().
 */
function ai_content_strategy_theme() {
  return [
    'ai_content_strategy_recommendations' => [
      'variables' => [
        'content_gaps' => [],
        'authority_topics' => [],
        'expertise_demonstrations' => [],
        'trust_signals' => [],
        'button_text' => [],
      ],
    ],
    'ai_content_strategy_recommendations_items' => [
      'variables' => [
        'items' => [],
        'section' => NULL,
        'section_config' => [],
        'button_text' => [],
      ],
    ],
  ];
}

/**
 * Implements hook_preprocess_HOOK().
 */
function ai_content_strategy_preprocess_ai_content_strategy_recommendations(&$variables) {
  // Define ALL button text in one central place
  $button_text = [
    // Main button states
    'main' => [
      'generate' => t('Generate Recommendations'),
      'refresh' => t('Refresh Recommendations'),
      'loading' => t('Generating recommendations...'),
      'loading_more' => t('Adding more recommendations...'),
    ],
    // Generate ideas for new items
    'generate' => [
      'content_gaps' => t('Generate ideas for this content gap'),
      'authority_topics' => t('Generate ideas for this authority topic'),
      'expertise_demonstrations' => t('Generate ideas for this %type'),
      'trust_signals' => t('Generate ideas for this trust signal'),
    ],
    // Generate more ideas for existing items
    'generate_more' => [
      'content_gaps' => t('Generate more ideas for this content gap'),
      'authority_topics' => t('Generate more ideas for this authority topic'),
      'expertise_demonstrations' => t('Generate more ideas for this %type'),
      'trust_signals' => t('Generate more ideas for this trust signal'),
    ],
    // Add more recommendations buttons
    'add_more' => [
      'content_gaps' => t('Discover More Content Opportunities'),
      'authority_topics' => t('Explore More Authority Topics'),
      'expertise_demonstrations' => t('Add More Ways to Showcase Expertise'),
      'trust_signals' => t('Find More Trust-Building Elements'),
    ],
  ];

  // Add to template variables
  $variables['button_text'] = $button_text;

  // Add to JavaScript settings
  $variables['#attached']['drupalSettings']['aiContentStrategy'] = [
    'buttonText' => $button_text,
  ];
} 
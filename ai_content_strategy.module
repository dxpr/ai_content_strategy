<?php

/**
 * @file
 * AI Content Strategy module.
 */

/**
 * Main button states.
 */
const AI_CONTENT_STRATEGY_BUTTON_MAIN = [
  'generate' => 'Generate Recommendations',
  'refresh' => 'Refresh Recommendations',
  'loading' => 'Generating recommendations...',
  'loading_more' => 'Adding more recommendations...',
];

/**
 * Generate ideas for new items.
 */
const AI_CONTENT_STRATEGY_BUTTON_GENERATE = [
  'content_gaps' => 'Generate ideas for this %type',
  'authority_topics' => 'Generate ideas for this %type',
  'expertise_demonstrations' => 'Generate ideas for this %type',
  'trust_signals' => 'Generate ideas for this %type',
];

/**
 * Generate more ideas for existing items.
 */
const AI_CONTENT_STRATEGY_BUTTON_GENERATE_MORE = [
  'content_gaps' => 'Generate more ideas for this %type',
  'authority_topics' => 'Generate more ideas for this %type',
  'expertise_demonstrations' => 'Generate more ideas for this %type',
  'trust_signals' => 'Generate more ideas for this %type',
];

/**
 * Add more recommendations buttons.
 */
const AI_CONTENT_STRATEGY_BUTTON_ADD_MORE = [
  'content_gaps' => 'Discover More %types',
  'authority_topics' => 'Explore More %types',
  'expertise_demonstrations' => 'Add More Ways to Showcase %types',
  'trust_signals' => 'Find More %types',
];

/**
 * Gets translated button texts.
 *
 * @return array
 *   Array of translated button texts.
 */
function ai_content_strategy_get_button_texts() {
  return [
    'main' => array_map('t', AI_CONTENT_STRATEGY_BUTTON_MAIN),
    'generate' => array_map('t', AI_CONTENT_STRATEGY_BUTTON_GENERATE),
    'generate_more' => array_map('t', AI_CONTENT_STRATEGY_BUTTON_GENERATE_MORE),
    'add_more' => array_map('t', AI_CONTENT_STRATEGY_BUTTON_ADD_MORE),
  ];
}

/**
 * Implements hook_theme().
 */
function ai_content_strategy_theme() {
  return [
    'ai_content_strategy_recommendations' => [
      'variables' => [
        'content_gaps' => [],
        'authority_topics' => [],
        'expertise_demonstrations' => [],
        'trust_signals' => [],
        'button_text' => [],
      ],
    ],
    'ai_content_strategy_recommendations_items' => [
      'variables' => [
        'items' => [],
        'section' => NULL,
        'section_config' => [],
        'button_text' => [],
      ],
    ],
  ];
}

/**
 * Implements hook_preprocess_HOOK().
 */
function ai_content_strategy_preprocess_ai_content_strategy_recommendations(&$variables) {
  // Get translated button texts
  $button_text = ai_content_strategy_get_button_texts();

  // Add to template variables
  $variables['button_text'] = $button_text;

  // Add to JavaScript settings
  $variables['#attached']['drupalSettings']['aiContentStrategy'] = [
    'buttonText' => $button_text,
  ];
} 
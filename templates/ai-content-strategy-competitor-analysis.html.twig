{#
/**
 * @file
 * Default theme implementation to display competitor analysis results.
 *
 * Available variables:
 * - competitor_url: The URL of the analyzed competitor site.
 * - content_gaps: Array of content gaps found.
 * - competitive_advantages: Array of competitive advantages.
 * - improvement_opportunities: Array of improvement opportunities.
 * - structural_insights: Array of structural insights.
 */
#}
<div class="competitor-analysis-wrapper">
  <div class="competitor-info">
    <h2>{{ 'Analysis Results for'|t }} <a href="{{ competitor_url }}" target="_blank">{{ competitor_url }}</a></h2>
  </div>

  {% if content_gaps %}
    <div class="analysis-section content-gaps">
      <h3>{{ 'Content Gaps'|t }}</h3>
      <div class="analysis-items">
        {% for gap in content_gaps %}
          <div class="analysis-item">
            <div class="item-header">
              <h4>{{ gap.title }}</h4>
              <span class="priority-badge priority-{{ gap.priority|lower }}">{{ gap.priority|title }}</span>
            </div>
            <p class="description">{{ gap.description }}</p>
            <div class="action-items">
              <h5>{{ 'Action Items'|t }}</h5>
              <ul>
                {% for action in gap.action_items %}
                  <li>{{ action }}</li>
                {% endfor %}
              </ul>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  {% endif %}

  {% if competitive_advantages %}
    <div class="analysis-section competitive-advantages">
      <h3>{{ 'Competitive Advantages'|t }}</h3>
      <div class="analysis-items">
        {% for advantage in competitive_advantages %}
          <div class="analysis-item">
            <h4>{{ advantage.area }}</h4>
            <p class="description">{{ advantage.description }}</p>
            <div class="leverage-ideas">
              <h5>{{ 'How to Leverage'|t }}</h5>
              <ul>
                {% for idea in advantage.leverage_ideas %}
                  <li>{{ idea }}</li>
                {% endfor %}
              </ul>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  {% endif %}

  {% if improvement_opportunities %}
    <div class="analysis-section improvement-opportunities">
      <h3>{{ 'Improvement Opportunities'|t }}</h3>
      <div class="analysis-items">
        {% for opportunity in improvement_opportunities %}
          <div class="analysis-item">
            <h4>{{ opportunity.category }}</h4>
            <p class="findings">{{ opportunity.findings }}</p>
            <div class="recommendations">
              <h5>{{ 'Recommendations'|t }}</h5>
              <ul>
                {% for recommendation in opportunity.recommendations %}
                  <li>{{ recommendation }}</li>
                {% endfor %}
              </ul>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  {% endif %}

  {% if structural_insights %}
    <div class="analysis-section structural-insights">
      <h3>{{ 'Structural Insights'|t }}</h3>
      <div class="analysis-items">
        {% for insight in structural_insights %}
          <div class="analysis-item">
            <h4>{{ insight.aspect }}</h4>
            <p class="comparison">{{ insight.comparison }}</p>
            <div class="optimization-steps">
              <h5>{{ 'Optimization Steps'|t }}</h5>
              <ul>
                {% for step in insight.optimization_steps %}
                  <li>{{ step }}</li>
                {% endfor %}
              </ul>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  {% endif %}
</div> 
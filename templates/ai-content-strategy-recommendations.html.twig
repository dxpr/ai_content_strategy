{#
/**
 * @file
 * Default theme implementation for content strategy recommendations.
 *
 * Available variables:
 * - content_gaps: Array of content gap recommendations.
 * - authority_topics: Array of authority topic recommendations.
 * - expertise_demonstrations: Array of expertise demonstration recommendations.
 * - trust_signals: Array of trust signal recommendations.
 *
 * @ingroup themeable
 */
#}
{{ attach_library('ai_content_strategy/recommendations') }}

<div{{ attributes.addClass('content-strategy-recommendations') }}>
  
  {# Content Gaps #}
  <div class="recommendation-section" data-section="content_gaps">
    <h3>{{ 'Content Gaps'|t }}</h3>
    {% if content_gaps is not empty %}
      <div class="recommendation-items">
        {{ content_gaps|theme('ai_content_strategy_recommendations_items', {'section': 'content_gaps'}) }}
      </div>
      <div class="add-more-recommendations-wrapper">
        <a href="#" class="add-more-recommendations-link button button--secondary" data-section="content_gaps">
          {{ 'Discover More Content Opportunities'|t }}
        </a>
      </div>
    {% else %}
      <p>{{ 'No content gaps identified.'|t }}</p>
    {% endif %}
  </div>

  {# Authority Topics #}
  <div class="recommendation-section" data-section="authority_topics">
    <h3>{{ 'Authority Topics'|t }}</h3>
    {% if authority_topics is not empty %}
      <div class="recommendation-items">
        {{ authority_topics|theme('ai_content_strategy_recommendations_items', {'section': 'authority_topics'}) }}
      </div>
      <div class="add-more-recommendations-wrapper">
        <a href="#" class="add-more-recommendations-link button button--secondary" data-section="authority_topics">
          {{ 'Explore More Authority Topics'|t }}
        </a>
      </div>
    {% else %}
      <p>{{ 'No authority topics identified.'|t }}</p>
    {% endif %}
  </div>

  {# Expertise Demonstrations #}
  <div class="recommendation-section" data-section="expertise_demonstrations">
    <h3>{{ 'Expertise Demonstrations'|t }}</h3>
    {% if expertise_demonstrations is not empty %}
      <div class="recommendation-items">
        {{ expertise_demonstrations|theme('ai_content_strategy_recommendations_items', {'section': 'expertise_demonstrations'}) }}
      </div>
      <div class="add-more-recommendations-wrapper">
        <a href="#" class="add-more-recommendations-link button button--secondary" data-section="expertise_demonstrations">
          {{ 'Add More Ways to Showcase Expertise'|t }}
        </a>
      </div>
    {% else %}
      <p>{{ 'No expertise demonstrations identified.'|t }}</p>
    {% endif %}
  </div>

  {# Trust Signals #}
  <div class="recommendation-section" data-section="trust_signals">
    <h3>{{ 'Trust Signals'|t }}</h3>
    {% if trust_signals is not empty %}
      <div class="recommendation-items">
        {{ trust_signals|theme('ai_content_strategy_recommendations_items', {'section': 'trust_signals'}) }}
      </div>
      <div class="add-more-recommendations-wrapper">
        <a href="#" class="add-more-recommendations-link button button--secondary" data-section="trust_signals">
          {{ 'Find More Trust-Building Elements'|t }}
        </a>
      </div>
    {% else %}
      <p>{{ 'No trust signals identified.'|t }}</p>
    {% endif %}
  </div>

</div> 
{#
/**
 * @file
 * Default theme implementation for content strategy recommendations.
 *
 * Available variables:
 * - categories: Array of recommendation categories with their items.
 * - button_text: Button text configuration.
 * - last_run: Last generation time as a formatted string.
 * - pages_analyzed: Number of pages analyzed from the sitemap.
 * - categories_count: Number of active recommendation categories.
 * - configure_link: Link to configure categories (optional).
 * - ai_configured: Whether the AI provider is configured and ready.
 *
 * @ingroup themeable
 */
#}
{{ attach_library('ai_content_strategy/recommendations') }}

<div{{ attributes.addClass('content-strategy-recommendations') }}>
  {% if configure_link %}
    {{ configure_link }}
  {% endif %}

  <div class="content-strategy-description">
    <p>{{ 'AI-powered content strategy recommendations based on your site structure.'|t }}</p>
  </div>

  {% if last_run %}
    <div class="content-strategy-status">
      <div class="status-item status-item--timestamp">
        <strong>{{ 'Last generated:'|t }}</strong> {{ last_run }}
      </div>
      {% if pages_analyzed %}
        <div class="status-item status-item--pages">
          <strong>{{ 'Pages analyzed:'|t }}</strong> {{ pages_analyzed }}
        </div>
      {% endif %}
      {% if categories_count %}
        <div class="status-item status-item--categories">
          <strong>{{ 'Active categories:'|t }}</strong> {{ categories_count }}
        </div>
      {% endif %}
    </div>
  {% endif %}

  <div class="content-strategy-actions">
    <button class="generate-recommendations button button--primary" data-has-existing="{{ last_run ? 'true' : 'false' }}"{{ not ai_configured ? ' disabled' : '' }}>
      {% if last_run %}
        {{ 'Regenerate recommendations'|t }}
      {% else %}
        {{ 'Generate recommendations'|t }}
      {% endif %}
    </button>
    {% if last_run %}
      <button class="export-csv-button button button--secondary">
        {{ 'Export as CSV'|t }}
      </button>
    {% endif %}
  </div>

  {% if categories is empty %}
    <div class="empty-recommendations">
      {{ 'Click the button above to generate content recommendations.'|t }}
    </div>
  {% else %}
    {% set has_items = false %}
    {% for category in categories %}
      {% if category.items is not empty %}
        {% set has_items = true %}
      {% endif %}
    {% endfor %}

    {% if not has_items %}
      <div class="empty-recommendations">
        {{ 'Click the button above to generate content recommendations.'|t }}
      </div>
    {% else %}
      <div class="recommendations-wrapper">
        {% for category in categories %}
          <div class="recommendation-section" data-section="{{ category.id }}">
            <h3>{{ category.label }}</h3>
            {% if category.items is not empty %}
              <div class="recommendation-items">
                {% include 'ai-content-strategy-recommendations-items.html.twig' with {
                  'items': category.items,
                  'section': category.id,
                  'button_text': button_text
                } %}
              </div>
              <div class="add-more-recommendations-wrapper">
                <a href="#" class="add-more-recommendations-link button button--secondary" data-section="{{ category.id }}">
                  {{ button_text.add_more[category.id] }}
                </a>
              </div>
            {% else %}
              <div class="empty-category-state">
                <p>{{ 'No recommendations yet. Click below to generate AI-powered content suggestions.'|t }}</p>
                <div class="add-more-recommendations-wrapper">
                  <a href="#" class="add-more-recommendations-link button button--primary" data-section="{{ category.id }}">
                    {{ button_text.generate[category.id] }}
                  </a>
                </div>
              </div>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    {% endif %}
  {% endif %}
</div> 
{#
/**
 * @file
 * Default theme implementation for content strategy recommendation items.
 *
 * Available variables:
 * - items: Array of recommendation items.
 * - section: The section identifier.
 * - section_config: Configuration for the section.
 * - button_text: Button text configuration.
 *
 * @ingroup themeable
 */
#}

{% for item in items %}
  {# Determine title field - try common fields in order #}
  {% set item_title = item.title|default(item.topic|default(item.content_type|default(item.signal|default('Recommendation'|t)))) %}
  {% if item_title is iterable and item_title['#markup'] is defined %}
    {% set item_title = item_title['#markup'] %}
  {% elseif item_title is iterable %}
    {% set item_title = item_title|first %}
  {% endif %}

  <div class="recommendation-item recommendation-priority-{{ item.priority }}" data-section="{{ section }}" data-title="{{ item_title }}">
    <div class="recommendation-content">
      <div class="recommendation-header">
        <h4 contenteditable="true" data-field="title" data-original="{{ item_title }}" class="editable-field">{{ item_title }}</h4>
        <button type="button" class="delete-card-link" data-section="{{ section }}" data-title="{{ item_title }}" title="{{ 'Delete this recommendation (cannot be undone)'|t }}" aria-label="{{ 'Delete recommendation: @title'|t({'@title': item_title}) }}">
          <span class="cs-icon cs-icon--trash" aria-hidden="true"></span>
        </button>
      </div>
      {# Try to find description - try common fields in order #}
      {% set description = item.description|default(item.rationale|default(item.implementation|default(null))) %}
      {% if description %}
        <p contenteditable="true" data-field="description" class="editable-field">{{ description is iterable and description['#markup'] is defined ? description['#markup'] : description }}</p>
      {% endif %}

      {% if item.priority %}
        <span class="priority-badge {{ item.priority }}">{{ item.priority|title|t }}</span>
      {% endif %}

      {% if item.content_ideas is not empty %}
        <table class="content-ideas-table">
          <thead>
            <tr>
              <th>{{ 'Content Ideas'|t }}</th>
              <th class="idea-actions-header"></th>
            </tr>
          </thead>
          <tbody>
            {% for key, idea in item.content_ideas %}
              {# Support both string ideas (legacy) and object ideas with implemented status #}
              {% set idea_text = idea.text is defined ? idea.text : idea %}
              {% set idea_implemented = idea.implemented is defined ? idea.implemented : false %}
              {% set idea_link = idea.link is defined ? idea.link : '' %}
              <tr data-idea-index="{{ key }}"{{ idea_implemented ? ' class="idea-implemented"' : '' }}>
                <td class="idea-content-cell">
                  <div contenteditable="true" data-field="content_ideas" data-idea-index="{{ key }}" class="editable-field">{{ idea_text is iterable and idea_text['#markup'] is defined ? idea_text['#markup'] : idea_text }}</div>
                  <div class="idea-link-area"{{ idea_implemented ? '' : ' style="display: none;"' }}>
                    {% if idea_link %}
                      <a href="{{ idea_link }}" target="_blank" class="idea-link" data-section="{{ section }}" data-title="{{ item_title }}" data-idea-index="{{ key }}">{{ idea_link }}</a>
                      <button type="button" class="idea-link-edit" data-section="{{ section }}" data-title="{{ item_title }}" data-idea-index="{{ key }}" title="{{ 'Edit link'|t }}">
                        <span class="cs-icon cs-icon--edit cs-icon--sm" aria-hidden="true"></span>
                      </button>
                    {% else %}
                      <button type="button" class="idea-add-link action-link button--small" data-section="{{ section }}" data-title="{{ item_title }}" data-idea-index="{{ key }}">{{ '+ Add link'|t }}</button>
                    {% endif %}
                  </div>
                </td>
                <td class="idea-actions">
                  <label class="idea-checkbox" title="{{ 'Mark as implemented'|t }}">
                    <input type="checkbox" class="idea-implemented-checkbox" data-section="{{ section }}" data-title="{{ item_title }}" data-idea-index="{{ key }}"{{ idea_implemented ? ' checked' : '' }}>
                    <span class="idea-checkbox-visual"></span>
                  </label>
                  <button type="button" class="delete-idea-link" data-section="{{ section }}" data-title="{{ item_title }}" data-idea-index="{{ key }}" title="{{ 'Delete this content idea'|t }}" aria-label="{{ 'Delete content idea'|t }}">
                    <span class="cs-icon cs-icon--trash cs-icon--md" aria-hidden="true"></span>
                  </button>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      {% endif %}
    </div>
    <div class="recommendation-actions">
      {% if item.content_ideas is not empty %}
        <a href="#" class="generate-more-link" data-section="{{ section }}" data-title="{{ item_title }}">
          {{ button_text.generate_more[section] }}
        </a>
      {% else %}
        <a href="#" class="generate-ideas-link button button--primary" data-section="{{ section }}" data-item="{{ item|json_encode }}">
          {{ button_text.generate[section] }}
        </a>
      {% endif %}
    </div>
  </div>
{% endfor %}
